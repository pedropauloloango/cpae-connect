# Copie para .env e preencha com os valores do seu projeto Supabase.
# cp .env.example .env   (Linux/macOS/Git Bash)
# copy .env.example .env (Windows CMD)

# =============================================================================
# Supabase LOCAL (padrão — requer Docker + `npm run supabase:start`)
# =============================================================================
# SUPABASE_URL="http://127.0.0.1:54321"
# SUPABASE_PUBLISHABLE_KEY="sua-anon-key-local"
# SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key-local"
# VITE_SUPABASE_URL="http://127.0.0.1:54321"
# VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key-local"

# =============================================================================
# Supabase CLOUD (Dashboard → Project Settings → API)
# =============================================================================
SUPABASE_URL="https://SEU-PROJETO.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sua-anon-key"
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"

# JWT local (server functions). Projeto com ECC: PUBLIC KEY em JWT Signing Keys → CURRENT KEY
SUPABASE_JWT_PUBLIC_KEY='{"keys":[{"x":"...","y":"...","alg":"ES256","crv":"P-256","kid":"...","kty":"EC","key_ops":["verify"]}]}'
# Alternativa legada (HS256): aba "Legacy JWT Secret"
SUPABASE_JWT_SECRET=""

VITE_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key"

# =============================================================================
# E-mail transacional (MailerSend — https://app.mailersend.com)
# =============================================================================
# Domínio verificado no MailerSend (ex.: daleal.com.br).
# Remetente deve usar esse domínio:
EMAIL_FROM="CPAE <noreply@daleal.com.br>"
# Token em MailerSend → API tokens (permissão: Enviando acesso)
MAILERSEND_API_TOKEN="mlsn.xxxxxxxx"
APP_URL="https://gestaocpae.vercel.app"
# Destinatários extras de alerta (opcional / legado — o app NÃO usa mais esta lista).
# Quem recebe alerta é definido em Configurações → Usuários (E-mail alerta Acolhimento / Vivências).
# ADMIN_NOTIFICATION_EMAILS="seu-email@exemplo.com"
