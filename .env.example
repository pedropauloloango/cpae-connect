# =============================================================================
# Supabase CLOUD (alternativa — copie do dashboard: Project Settings > API)
# =============================================================================
# SUPABASE_URL="https://SEU-PROJETO.supabase.co"
# SUPABASE_PUBLISHABLE_KEY="sua-anon-key"
# SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"
# Validação JWT local no servidor (rede corporativa). Use a chave pública se o projeto usa ECC:
# Dashboard → Project Settings → API → JWT Keys → aba "JWT Signing Keys" → CURRENT KEY → public key
# SUPABASE_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----..."
# Ou, se ainda usar Legacy HS256: aba "Legacy JWT Secret"
# SUPABASE_JWT_SECRET="sua-jwt-secret"
# VITE_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
# VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key"
